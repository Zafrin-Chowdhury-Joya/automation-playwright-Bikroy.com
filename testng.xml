<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="TestSuite">
    <listeners>
    <listener class-name="com.automation.tests.TestLogger"/>
     </listeners>


    <test name="Chromium Tests">
        <parameter name="browser" value="chromium"/>
        <classes>
            <class name="com.automation.tests.LoginTest"/>
            <class name="com.automation.tests.AddToCartTest"/>
         
            

        </classes>
    </test>


    <!--
    To run tests in parallel on multiple browsers, uncomment and configure like this:

    <test name="Firefox Tests" parallel="tests" thread-count="3">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.automation.tests.LoginTest"/>
        </classes>
    </test>

    <test name="WebKit Tests" parallel="tests" thread-count="3">
        <parameter name="browser" value="webkit"/>
        <classes>
            <class name="com.automation.tests.LoginTest"/>
        </classes>
    </test>
    -->

</suite>
